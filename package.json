{
  "name": "odinn",
  "version": "0.1.0",
  "private": true,
  "description": "Ódinn Forge cross-platform personal AI agent runtime",
  "type": "module",
  "bin": {
    "odinn": "./apps/cli/src/cli.ts"
  },
  "packageManager": "pnpm@10.14.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "format:check": "node scripts/ci/run.ts format",
    "lint": "node scripts/ci/run.ts lint",
    "typecheck": "node scripts/ci/run.ts typecheck",
    "test": "node --test --test-reporter=spec tests/*.test.ts",
    "test:platform": "node --test --test-reporter=spec tests/platform.test.ts",
    "test:integration": "node --test --test-reporter=spec tests/integration.test.ts",
    "build": "node scripts/ci/run.ts build",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "odinn": "node ./apps/cli/src/cli.ts",
    "onboard": "pnpm --filter @odinn/cli start -- onboard",
    "tui": "pnpm --filter @odinn/cli start -- tui",
    "gui:start": "pnpm --filter @odinn/gateway start",
    "host:start": "node apps/gateway/src/host.ts",
    "smoke:inference": "node scripts/ci/inference-smoke.ts",
    "smoke:onboarding": "node scripts/ci/onboarding-smoke.ts",
    "storage:drill": "node scripts/ci/storage-drill.ts",
    "benchmark:ci": "node scripts/ci/benchmark.ts",
    "release:preflight": "node scripts/release/preflight.ts",
    "release:package": "node scripts/release/package.ts",
    "release:checksums": "node scripts/release/checksums.ts",
    "release:install-smoke": "node scripts/release/install-smoke.ts"
  },
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "24.10.1",
    "eslint": "10.7.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.64.0"
  }
}
